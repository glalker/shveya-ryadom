# Скопируйте этот файл в server/.env и заполните значения.
# Файл .env в репозиторий не попадает (см. .gitignore).

# Порт, на котором работает сайт локально
PORT=3000

# --- Настройки MAX (мессенджер) ---
# Токен бота. Получается при создании бота в приложении MAX
# (системный бот-помощник для разработчиков). Никому не показывайте.
MAX_BOT_TOKEN=

# ID получателя заявок (мамы) ИЛИ группового чата.
# Как узнать: мама один раз пишет боту любое сообщение, затем смотрим
# обновления бота — см. инструкцию в README.md (раздел «Настройка MAX»).
MAX_RECIPIENT_ID=

# Тип получателя: user — личный диалог с мамой, chat — группа/чат.
MAX_RECIPIENT_TYPE=user

# Базовый адрес Bot API MAX. Менять обычно не нужно.
# Рабочий хост (проверено в 2026): https://botapi.max.ru
# Авторизация — заголовок Authorization с токеном (query access_token устарел).
MAX_API_BASE=https://botapi.max.ru
